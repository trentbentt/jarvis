#!/home/monarch/venv/inference/bin/python
"""
jarvis-q — Jarvis state query CLI v0.1

Reads ~/.local/state/jarvis/state.json (written by daemon every 30s).
Works without the daemon running — reads last-known state from disk.

Usage:
    jarvis-q vram          VRAM usage by tier + OOM risk
    jarvis-q health        Service health across all components
    jarvis-q tiers         Tier state, model, context, performance
    jarvis-q workloads     Active and recent completed workloads
    jarvis-q quotas        Cloud API budget status
    jarvis-q events [N]    Last N events (default 20)
    jarvis-q all           Full summary
    jarvis-q json          Raw JSON state dump
"""

from __future__ import annotations

import json
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

# Allow running as a script from any directory
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from jarvis.schema import HealthStatus, OOMRisk, TierState
from jarvis.state import StateStore

# ─── Colour helpers ────────────────────────────────────────────────────────────

def _c(text: str, code: str) -> str:
    return f"\033[{code}m{text}\033[0m"

def red(t: str) -> str:    return _c(t, "31")
def green(t: str) -> str:  return _c(t, "32")
def yellow(t: str) -> str: return _c(t, "33")
def blue(t: str) -> str:   return _c(t, "36")
def bold(t: str) -> str:   return _c(t, "1")
def dim(t: str) -> str:    return _c(t, "2")


def _ago(dt: Optional[datetime]) -> str:
    if dt is None:
        return dim("never")
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    secs = int((datetime.now(timezone.utc) - dt).total_seconds())
    if secs < 60:
        return f"{secs}s ago"
    elif secs < 3600:
        return f"{secs // 60}m ago"
    elif secs < 86400:
        return f"{secs // 3600}h {(secs % 3600) // 60}m ago"
    else:
        return f"{secs // 86400}d ago"


def _bar(used: int, total: int, width: int = 20) -> str:
    pct = used / total if total else 0
    filled = int(pct * width)
    bar = "█" * filled + "░" * (width - filled)
    color = red if pct > 0.90 else yellow if pct > 0.75 else green
    return f"[{color(bar)}] {pct*100:.1f}%"


# ─── Subcommands ──────────────────────────────────────────────────────────────

def cmd_vram(model) -> None:
    v = model.resources.vram
    target_pct = getattr(v, 'baseline_target_pct', 80.0)
    target_mb = int(v.total_mb * target_pct / 100)
    target_headroom_mb = target_mb - v.used_mb   # negative if over target
    actual_pct = (v.used_mb / v.total_mb) * 100 if v.total_mb else 0
    over_target = v.used_mb > target_mb

    print(bold("── VRAM ─────────────────────────────────────────────────"))
    print(f"  Total    : {v.total_mb:,} MiB")
    print(f"  Used     : {v.used_mb:,} MiB  {_bar(v.used_mb, v.total_mb)}")
    print(f"  Free     : {v.free_mb:,} MiB")

    # Target line — visible every query
    target_color = red if over_target else green
    target_marker = "OVER" if over_target else "OK  "
    print(f"  Target   : {target_mb:,} MiB ({target_pct:.0f}%)  "
          f"{target_color(target_marker)}  "
          f"headroom: {target_color(f'{target_headroom_mb:+,} MiB')}")

    risk_str = {
        OOMRisk.LOW: green("LOW"),
        OOMRisk.ELEVATED: yellow("ELEVATED ⚠"),
        OOMRisk.IMMINENT: red("IMMINENT 🔴"),
    }.get(v.oom_risk, str(v.oom_risk))
    print(f"  OOM risk : {risk_str}")

    if over_target:
        excess = v.used_mb - target_mb
        print(f"  {yellow('⚠')} Baseline {excess:,} MiB ({actual_pct - target_pct:+.1f}pp) over {target_pct:.0f}% target")

    print()
    print("  By tier:")
    tier_vram = {
        "t1": v.used_by_tier.t1,
        "t2": v.used_by_tier.t2,
        "t3": v.used_by_tier.t3,
        "t4": v.used_by_tier.t4,
        "t5": v.used_by_tier.t5,
        "t6": v.used_by_tier.t6,
        "driver": v.used_by_tier.driver_display,
        "other": v.used_by_tier.other,
    }
    for name, mb in tier_vram.items():
        if mb > 0:
            bar = _bar(mb, v.total_mb, width=12)
            print(f"    {name:<8}: {mb:>6,} MiB  {bar}")

    updated = _ago(v.updated_at)
    print(f"\n  Updated  : {updated}")


def cmd_health(model) -> None:
    print(bold("── Health ───────────────────────────────────────────────"))
    for comp in model.health.components:
        status_str = {
            HealthStatus.OK:           green("OK          "),
            HealthStatus.UNRESPONSIVE: red("UNRESPONSIVE"),
            HealthStatus.DEGRADED:     yellow("DEGRADED    "),
            HealthStatus.STOPPED:      dim("STOPPED     "),
            HealthStatus.IDLE:         dim("IDLE        "),
            HealthStatus.ERROR:        red("ERROR       "),
            HealthStatus.UNKNOWN:      dim("UNKNOWN     "),
        }.get(comp.status, str(comp.status))

        ms_str = f"{comp.response_ms}ms" if comp.response_ms else "—"
        port_str = f":{comp.port}" if comp.port else ""
        last_ok = _ago(comp.last_seen_healthy) if comp.status not in (HealthStatus.OK, HealthStatus.IDLE) else ""
        detail = f"  {dim(comp.detail)}" if comp.detail else ""

        print(f"  {comp.name:<24} {status_str}  {ms_str:<6}  {port_str:<6}{last_ok}{detail}")

    sweep = _ago(model.health.last_full_sweep)
    print(f"\n  Last sweep: {sweep}")


def cmd_tiers(model) -> None:
    print(bold("── Tiers ────────────────────────────────────────────────"))
    for tier_id in ("t1", "t2", "t3", "t4", "t5", "t6"):
        tier = model.tiers.get(tier_id)
        if tier is None:
            continue

        state_str = {
            TierState.ACTIVE:       green("ACTIVE      "),
            TierState.STOPPED:      dim("STOPPED     "),
            TierState.FAILED:       red("FAILED      "),
            TierState.OFFLINE:      dim("OFFLINE     "),
            TierState.STARTING:     yellow("STARTING    "),
            TierState.STOPPING:     yellow("STOPPING    "),
            TierState.SOFT_OFFLOAD: yellow("SOFT_OFFLOAD"),
        }.get(tier.runtime.state, str(tier.runtime.state))

        cfg = tier.config
        vram = tier.resources.vram_used_mb
        tok = tier.performance.tok_per_sec_recent
        tok_str = f"{tok:.0f} tok/s" if tok else "—"
        lora = f"  lora:{cfg.active_lora}" if cfg.active_lora else ""
        offload = f"  offload:{cfg.expert_offload_pct}%" if cfg.expert_offload_pct else ""
        cpu_tag = "  [CPU]" if cfg.cpu_only else ""

        print(f"  {tier_id.upper()}  {state_str}  "
              f"{cfg.model:<18} {cfg.quant:<12}  "
              f"ctx:{cfg.context_size//1024}K  "
              f"port:{cfg.port}  "
              f"vram:{vram:>5,}MiB  "
              f"{tok_str}"
              f"{lora}{offload}{cpu_tag}")


def cmd_workloads(model) -> None:
    print(bold("── Workloads ────────────────────────────────────────────"))
    active = model.workloads.active
    if active:
        print(f"  {bold('Active')} ({len(active)}):")
        for w in active:
            eta = f"  ETA:{_ago(w.expected_completion)}" if w.expected_completion else ""
            pct = f"  {w.progress_pct}%" if w.progress_pct is not None else ""
            print(f"    [{w.priority.upper():<6}] {w.workload_id}  "
                  f"({w.type.value})  started {_ago(w.started_at)}{eta}{pct}")
            if w.progress_detail:
                print(f"             {dim(w.progress_detail)}")
    else:
        print(f"  {dim('No active workloads')}")

    recent = model.workloads.completed[-10:]
    if recent:
        print(f"\n  {bold('Recent completed')} (last {len(recent)}):")
        for w in reversed(recent):
            outcome_str = {
                "success": green("✓"),
                "failed": red("✗"),
                "timeout": yellow("⏱"),
                "killed": red("☠"),
                "partial": yellow("~"),
            }.get(w.outcome.value, "?")
            sla = green(" SLA✓") if w.sla_met else (red(" SLA✗") if w.sla_met is False else "")
            print(f"    {outcome_str} {w.workload_id:<45} {w.duration_sec}s{sla}  {_ago(w.completed_at)}")


def cmd_quotas(model) -> None:
    print(bold("── Quotas ───────────────────────────────────────────────"))
    if not model.quotas.quotas:
        print(f"  {dim('No quota data yet — quota_listener not running')}")
        return
    for name, q in model.quotas.quotas.items():
        status_str = {
            "ok": green("OK"),
            "approaching_wall": yellow("APPROACHING"),
            "walled": red("WALLED"),
        }.get(q.status.value, q.status.value)

        if q.used_pct is not None:
            usage = f"{q.used_pct:.0f}% used  {_bar(int(q.used_pct), 100, width=12)}"
        elif q.used_usd is not None and q.budget_usd:
            pct = q.used_usd / q.budget_usd * 100
            usage = f"${q.used_usd:.2f} / ${q.budget_usd:.2f}  {_bar(int(pct), 100, width=12)}"
        else:
            usage = dim("no data")

        wall = f"  wall:{_ago(q.projected_wall_at)}" if q.projected_wall_at else ""
        print(f"  {name:<20} {status_str:<12}  {usage}{wall}")


def cmd_events(model, n: int = 20) -> None:
    print(bold(f"── Events (last {n}) ─────────────────────────────────────"))
    events = model.events.log[-n:]
    if not events:
        print(f"  {dim('No events recorded yet')}")
        return
    for e in reversed(events):
        sev_str = {
            "info":     dim("INFO    "),
            "warning":  yellow("WARN    "),
            "critical": red("CRIT    "),
        }.get(e.severity, e.severity[:8].ljust(8))

        tier_tag = f"[{e.tier}] " if e.tier else ""
        print(f"  {_ago(e.timestamp):<12}  {sev_str}  {tier_tag}{e.type}"
              + (f"  {dim(e.detail)}" if e.detail else ""))


def cmd_all(model) -> None:
    ts = model.last_updated
    if ts and ts.tzinfo is None:
        ts = ts.replace(tzinfo=timezone.utc)
    age = _ago(ts) if ts else "unknown"
    print(bold(f"═══ Jarvis System Model  [updated {age}] ═══"))
    print()
    cmd_vram(model);    print()
    cmd_health(model);  print()
    cmd_tiers(model);   print()
    cmd_workloads(model); print()
    cmd_quotas(model);  print()
    cmd_events(model, n=10)


# ─── Entry point ──────────────────────────────────────────────────────────────

USAGE = """\
Usage: jarvis-q <command> [args]

Commands:
  vram          VRAM by tier + OOM risk
  health        Service health checks
  tiers         Tier state and performance
  workloads     Active and recent workloads
  quotas        Cloud API budget status
  events [N]    Last N events (default 20)
  all           Full summary
  json          Raw state dump
  skill-drafts  List pending Hermes skill drafts (stub; full impl with memory.py)
  evercore      EverCore (L7) substrate detail — ES/Milvus/Mongo/Redis/API + rerank
  profile-drift EverCore profile drift digest vs vault operator.md (§15 Item 13)
"""


# P1.5-4 Step 8 stub — list ~/.hermes/skill-drafts/ contents.
# Full implementation (mtime, summary, promotion gates) lands with the
# memory.py listener per master_summary_v20 §12.4 / MEMORY_ARCHITECTURE §10.2.
def cmd_skill_drafts() -> None:
    import os
    drafts_dir = os.path.expanduser("~/.hermes/skill-drafts")
    if not os.path.isdir(drafts_dir):
        print(dim(f"No skill-drafts dir at {drafts_dir}"))
        print(dim("(Hermes draft-state pattern not yet bootstrapped — see P1.5-4 Step 8.)"))
        return
    entries = sorted(e for e in os.listdir(drafts_dir) if not e.startswith("."))
    print("Hermes skill drafts (~/.hermes/skill-drafts/):")
    if not entries:
        print(dim("  (none — drafts dir is empty)"))
        return
    for name in entries:
        skill_path = os.path.join(drafts_dir, name, "SKILL.md")
        marker = "✓" if os.path.isfile(skill_path) else "?"
        print(f"  {marker} {name}")
    print(dim("Review with: invoke `approve-draft` skill in Hermes."))

def cmd_profile_drift() -> None:
    """Show the EverCore profile-drift digest (§15 Item 13). Reads the JSON
    written by ~/monarch-stack/evercore_profile_drift_check.sh (nightly 03:00 ET)."""
    import os
    f = os.path.expanduser("~/.local/state/jarvis/evercore_profile_drift.json")
    print(bold("── EverCore Profile Drift (§15 Item 13) ─────────────────"))
    if not os.path.isfile(f):
        print(dim(f"  No digest at {f}"))
        print(dim("  (Run evercore_profile_drift_check.sh — nightly cron 03:00 ET.)"))
        return
    d = json.load(open(f))
    drift = d.get("drift")
    print(f"  Status : {red('DRIFT ⚠') if drift else green('no drift')}")
    print(f"  Checked: {d.get('timestamp')}")
    if d.get("note"):
        print(f"  Note   : {dim(d['note'])}")
    added, removed = d.get("added", []), d.get("removed", [])
    if added:
        print(f"  {yellow('Added since baseline')} ({len(added)}):")
        for a in added[:20]:
            print(f"    {green('+')} {a}")
    if removed:
        print(f"  {yellow('Removed since baseline')} ({len(removed)}):")
        for r in removed[:20]:
            print(f"    {red('-')} {r}")
    if d.get("vault_changed_since_baseline"):
        print(f"  {yellow('⚠ vault operator.md changed since baseline')}")
    if not drift:
        print(dim(f"  {d.get('live_fact_count', d.get('fact_count','?'))} profile facts tracked"))
    print(dim("\n  After operator review: evercore_profile_drift_check.sh --acknowledge"))


def cmd_evercore(model) -> None:
    """EverCore (L7) substrate detail — composite health sub-probes + rerank."""
    print(bold("── EverCore (L7 EverMemOS) ──────────────────────────────"))
    comps = {c.name: c for c in model.health.components}
    ev = comps.get("evercore")
    if ev is None:
        print(dim("  evercore not registered yet — restart the daemon to pick up schema."))
        return
    ev_str = {
        HealthStatus.OK: green("OK"), HealthStatus.UNRESPONSIVE: red("DOWN"),
        HealthStatus.DEGRADED: yellow("DEGRADED"), HealthStatus.UNKNOWN: dim("UNKNOWN"),
    }.get(ev.status, str(ev.status))
    ms = f"{ev.response_ms}ms" if ev.response_ms else "—"
    print(f"  Overall  : {ev_str}  ({ms}, checked {_ago(ev.last_check)})")
    if ev.detail:
        print("  Substrate:")
        for tok in ev.detail.split():
            if ":" in tok:
                label, st = tok.split(":", 1)
                print(f"    {label:<8}: {green('ok') if st == 'ok' else red(st)}")
    rr = comps.get("rerank-bge")
    if rr is not None:
        rs = green("OK") if rr.status == HealthStatus.OK else red(str(rr.status))
        print(f"  rerank-bge :8088 : {rs}")
    print(dim("  Redis published on :6380 (6379 reserved for P1.5-6 L1 Redis)"))


def main() -> None:
    args = sys.argv[1:]
    if not args:
        print(USAGE)
        sys.exit(0)

    cmd = args[0].lower()

    # skill-drafts and profile-drift read the filesystem directly; no state file needed.
    if cmd == "skill-drafts":
        cmd_skill_drafts()
        return
    if cmd == "profile-drift":
        cmd_profile_drift()
        return

    model = StateStore.load_from_disk()
    if model is None:
        if cmd == "json":
            print("{}")
            sys.exit(1)
        print(red(f"No state file found at {StateStore.__module__}"))
        print(dim("Is the Jarvis daemon running?  tmux attach -t inference → jarvis window"))
        print(dim("Or: cd ~/projects/jarvis && python3 daemon.py"))
        sys.exit(1)

    if cmd == "vram":
        cmd_vram(model)
    elif cmd == "health":
        cmd_health(model)
    elif cmd == "tiers":
        cmd_tiers(model)
    elif cmd == "workloads":
        cmd_workloads(model)
    elif cmd == "quotas":
        cmd_quotas(model)
    elif cmd == "events":
        n = int(args[1]) if len(args) > 1 else 20
        cmd_events(model, n)
    elif cmd == "evercore":
        cmd_evercore(model)
    elif cmd == "all":
        cmd_all(model)
    elif cmd == "json":
        print(json.dumps(model.model_dump(mode="json"), indent=2, default=str))
    else:
        print(f"Unknown command: {cmd}")
        print(USAGE)
        sys.exit(1)


if __name__ == "__main__":
    main()
